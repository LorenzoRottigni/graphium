# Graphium

- automated isolated unit testing on nodes
- allow nested graphs visualization
- allow metrics tracking like:
    node! {
        #[metrics = ["call"]]
        async fn get_number() -> u32 {
            7
        }
    }
- allow event bus publish like:
    node! {
        #[publish = EventName]
        async fn get_number() -> u32 {
            7
        }
    }
- allow nodes explicit naming:
    node! {
        #[name = GetNumber]
        async fn get_number() -> u32 {
            7
        }
    }
- track graph performances at each node
    node! {
        #[performance = true]
        async fn get_number() -> u32 {
            7
        }
    }