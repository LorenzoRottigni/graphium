FROM rust:1.88-bookworm AS builder

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

RUN cargo build -p graphium-examples --bin ecommerce_ui --release --features full

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/ecommerce_ui /app/ecommerce_ui
COPY --from=builder /app/crates/ui/assets /app/crates/ui/assets

ENV GRAPHIUM_UI_BIND=0.0.0.0:4000
EXPOSE 4000
CMD ["/app/ecommerce_ui"]
